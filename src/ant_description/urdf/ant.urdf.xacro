<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ant_robot_body">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" /> 

    <xacro:include filename="ant.core.xacro" /> 
    <xacro:include filename="ant.ros2_control.xacro" /> 
    <xacro:include filename="ant.gazebo.xacro" /> 

    <xacro:ant_ros2_control name="GazeboSystem" initial_positions_file="$(arg initial_positions_file)"/>
</robot>